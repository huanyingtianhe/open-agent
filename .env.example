# Which LLM backend to talk to. Pick one:  anthropic | copilot | azure-openai
LLM_PROVIDER=copilot

# --- Anthropic (default) ----------------------------------------------------
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-sonnet-4-5

# --- GitHub Copilot --------------------------------------------------------
# Requires an active Copilot subscription.
# Auth precedence: GITHUB_COPILOT_TOKEN -> GITHUB_TOKEN -> `gh auth token`.
# Uncomment and switch LLM_PROVIDER=copilot to use:
# COPILOT_MODEL=claude-sonnet-4.5
# GITHUB_TOKEN=ghp_...

# --- Azure OpenAI ----------------------------------------------------------
# Endpoint shape: https://<resource>.openai.azure.com  (no trailing slash needed)
# Auth: either AZURE_OPENAI_API_KEY (api-key header) or AZURE_OPENAI_BEARER_TOKEN (AAD).
# Uncomment and switch LLM_PROVIDER=azure-openai to use:
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_BEARER_TOKEN=...
