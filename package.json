{
  "name": "open-agent",
  "version": "0.1.0",
  "description": "A minimal Claude-Code-style agent. Implements chapters s01-s07 of https://learn.shareai.run/en/",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "openagent": "dist/cli.js",
    "open-agent": "dist/cli.js"
  },
  "files": [
    "dist/",
    "skills/",
    "plugins/",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "tsx --test \"tests/**/*.test.ts\"",
    "test:cli": "npm run build && node dist/cli.js --help && node dist/cli.js --version",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
